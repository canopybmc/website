<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Canopy Blog</title>
    <meta name="description" content="{{ description or excerpt }}">
    
    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description or excerpt }}">
    <meta property="og:type" content="article">
    <meta property="og:url" content="https://canopybmc.org{{ page.url }}">
    {% if image %}
    <meta property="og:image" content="https://canopybmc.org{{ image }}">
    {% else %}
    <meta property="og:image" content="https://canopybmc.org/assets/images/canopy-og.png">
    {% endif %}
    <meta property="og:site_name" content="Canopy">
    <meta property="article:published_time" content="{{ date | isoDate }}">
    {% if tags %}
    {% for tag in tags %}{% if tag != "blog" %}
    <meta property="article:tag" content="{{ tag }}">
    {% endif %}{% endfor %}
    {% endif %}
    
    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description or excerpt }}">
    {% if image %}
    <meta name="twitter:image" content="https://canopybmc.org{{ image }}">
    {% else %}
    <meta name="twitter:image" content="https://canopybmc.org/assets/images/canopy-og.png">
    {% endif %}
    
    <!-- Additional SEO Meta Tags -->
    <meta name="author" content="{% if author and authors[author] %}{{ authors[author].name }}{% else %}Canopy Team{% endif %}">
    <link rel="canonical" href="https://canopybmc.org{{ page.url }}">
    
    <!-- RSS Feed -->
    <link rel="alternate" type="application/atom+xml" title="Canopy Blog" href="/feed.xml">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Styles -->
    <link rel="stylesheet" href="/assets/css/canopy.css">
    
    <!-- Structured Data - BlogPosting -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "{{ title }}",
      "description": "{{ description }}",
      "datePublished": "{{ date | isoDate }}",
      "dateModified": "{{ date | isoDate }}",
      "url": "https://canopybmc.org{{ page.url }}",
      {% if image %}"image": "https://canopybmc.org{{ image }}",{% endif %}
      "author": {
        "@type": "Person",
        "name": "{% if author and authors[author] %}{{ authors[author].name }}{% else %}Canopy Team{% endif %}"{% if author and authors[author] and authors[author].url %},
        "url": "{{ authors[author].url }}"{% endif %}
      },
      "publisher": {
        "@type": "Organization",
        "name": "Canopy",
        "url": "https://canopybmc.org",
        "logo": {
          "@type": "ImageObject",
          "url": "https://canopybmc.org/assets/images/canopy_logo.svg"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://canopybmc.org{{ page.url }}"
      }
    }
    </script>
</head>
<body>
    <header class="site-header">
        <nav class="navbar">
            <div class="nav-container">
                <div class="nav-brand">
                    <a href="/" class="logo">
                        <img src="/assets/images/canopy_logo.svg" alt="Canopy logo" width="120" height="31">
                    </a>
                </div>
                
                <button class="mobile-menu-toggle" aria-label="Toggle mobile menu" aria-expanded="false">
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                </button>
                
                <div class="nav-menu">
                    <ul class="nav-links">
                        <li><a href="/" class="nav-link">Home</a></li>
                        <li><a href="/philosophy" class="nav-link">Philosophy</a></li>
                        <li><a href="/boards" class="nav-link">Boards</a></li>
                        <li><a href="/releases" class="nav-link">Releases</a></li>
                        <li><a href="/blog" class="nav-link active">Blog</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="main-content">
        <article class="blog-post">
            <header class="blog-post-header">
                <div class="blog-post-header-inner">
                    <a href="/blog" class="blog-back-link">&larr; Back to Blog</a>
                    
                    {% if tags %}
                    <div class="blog-post-tags">
                        {% for tag in tags %}{% if tag != "blog" %}
                        <span class="blog-tag">{{ tag }}</span>
                        {% endif %}{% endfor %}
                    </div>
                    {% endif %}
                    
                    <h1 class="blog-post-title">{{ title }}</h1>
                    
                    {% if description %}
                    <p class="blog-post-description">{{ description }}</p>
                    {% endif %}
                    
                    <div class="blog-post-meta">
                        {% if author and authors[author] %}
                        <div class="blog-post-author">
                            <span class="blog-post-author-name">{{ authors[author].name }}</span>
                            {% if authors[author].role %}
                            <span class="blog-post-author-role">{{ authors[author].role }}</span>
                            {% endif %}
                        </div>
                        {% endif %}
                        <div class="blog-post-date-info">
                            <time datetime="{{ date | isoDate }}">{{ date | postDate }}</time>
                            <span class="blog-post-reading-time">{{ content | readingTime }}</span>
                        </div>
                    </div>
                </div>
            </header>
            
            <div class="blog-post-content">
                {{ content | safe }}
            </div>
            
            <footer class="blog-post-footer">
                <div class="blog-post-footer-inner">
                    <div class="blog-post-share">
                        <span class="blog-share-label">Share this post:</span>
                        <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://canopybmc.org{{ page.url }}" target="_blank" rel="noopener" class="blog-share-link">LinkedIn</a>
                        <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url=https://canopybmc.org{{ page.url }}" target="_blank" rel="noopener" class="blog-share-link">Twitter</a>
                        <a href="https://news.ycombinator.com/submitlink?u=https://canopybmc.org{{ page.url }}&t={{ title | urlencode }}" target="_blank" rel="noopener" class="blog-share-link">Hacker News</a>
                    </div>
                    
                    <a href="/blog" class="blog-back-link">&larr; All posts</a>
                </div>
            </footer>
        </article>
    </main>

    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-content">
                <div class="footer-section">
                    <h4>Canopy</h4>
                    <p>Open. Stable. Ready.</p>
                </div>
                
                <div class="footer-section">
                    <h4>Links</h4>
                    <ul>
                        <li><a href="https://github.com/canopybmc" target="_blank" rel="noopener">Canopy GitHub Repository</a></li>
                        <li><a href="/releases">Releases</a></li>
                        <li><a href="/blog">Blog</a></li>
                        <li><a href="/feed.xml">RSS Feed</a></li>
                        <li><a href="/sitemap.xml">Sitemap</a></li>
                    </ul>
                </div>
                
                <div class="footer-section">
                    <h4>Community</h4>
                    <ul>
                        <li><a href="https://lists.9elements.com/postorius/lists/canopy.lists.9elements.com/" target="_blank" rel="noopener">Mailing List</a></li>
                        <li><a href="#" target="_blank" rel="noopener" aria-label="Community discussions (coming soon)">Discussions</a></li>
                        <li><a href="#" target="_blank" rel="noopener" aria-label="Issue tracker (coming soon)">Issues</a></li>
                    </ul>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p>&copy; 2025 Canopy Project. Open source firmware for everyone.</p>
                <p class="sponsorship">Sponsored by <a href="https://9elements.com" target="_blank" rel="noopener">9elements</a></p>
            </div>
        </div>
    </footer>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const mobileMenuToggle = document.querySelector('.mobile-menu-toggle');
            const navMenu = document.querySelector('.nav-menu');
            
            if (mobileMenuToggle && navMenu) {
                mobileMenuToggle.addEventListener('click', function() {
                    navMenu.classList.toggle('active');
                    mobileMenuToggle.classList.toggle('active');
                    const isExpanded = navMenu.classList.contains('active');
                    mobileMenuToggle.setAttribute('aria-expanded', isExpanded);
                });
                
                const navLinks = document.querySelectorAll('.nav-link');
                navLinks.forEach(link => {
                    link.addEventListener('click', function() {
                        navMenu.classList.remove('active');
                        mobileMenuToggle.classList.remove('active');
                        mobileMenuToggle.setAttribute('aria-expanded', 'false');
                    });
                });
                
                document.addEventListener('click', function(event) {
                    if (!event.target.closest('.nav-container')) {
                        navMenu.classList.remove('active');
                        mobileMenuToggle.classList.remove('active');
                        mobileMenuToggle.setAttribute('aria-expanded', 'false');
                    }
                });
            }
        });
    </script>
</body>
</html>
